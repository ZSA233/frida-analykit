{
  "name": "@zsa233/frida-analykit-agent",
  "version": "2.0.2",
  "description": "Frida agent runtime for frida-analykit",
  "keywords": [
    "frida",
    "reverse-engineering",
    "instrumentation",
    "typescript"
  ],
  "homepage": "https://github.com/ZSA233/frida-analykit#readme",
  "bugs": {
    "url": "https://github.com/ZSA233/frida-analykit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZSA233/frida-analykit.git",
    "directory": "packages/frida-analykit-agent"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./bridges": {
      "types": "./dist/bridges.d.ts",
      "default": "./dist/bridges.js"
    },
    "./helper": {
      "types": "./dist/helper.d.ts",
      "default": "./dist/helper.js"
    },
    "./process": {
      "types": "./dist/process.d.ts",
      "default": "./dist/process.js"
    },
    "./jni": {
      "types": "./dist/jni.d.ts",
      "default": "./dist/jni.js"
    },
    "./ssl": {
      "types": "./dist/ssl.d.ts",
      "default": "./dist/ssl.js"
    },
    "./elf": {
      "types": "./dist/elf.d.ts",
      "default": "./dist/elf.js"
    },
    "./libssl": {
      "types": "./dist/libssl.d.ts",
      "default": "./dist/libssl.js"
    },
    "./rpc": {
      "types": "./dist/rpc.d.ts",
      "default": "./dist/rpc.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.type-tests.json --noEmit"
  },
  "dependencies": {
    "frida-java-bridge": "^7.0.8"
  },
  "devDependencies": {
    "@types/frida-gum": "^18.7.2",
    "typescript": "^5.8.3"
  }
}
