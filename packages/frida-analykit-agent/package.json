{
  "name": "@zsa233/frida-analykit-agent",
  "version": "2.0.7",
  "description": "Frida agent runtime for frida-analykit",
  "keywords": [
    "frida",
    "reverse-engineering",
    "instrumentation",
    "typescript"
  ],
  "homepage": "https://github.com/ZSA233/frida-analykit/blob/main/packages/frida-analykit-agent/README.md",
  "bugs": {
    "url": "https://github.com/ZSA233/frida-analykit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZSA233/frida-analykit.git",
    "directory": "packages/frida-analykit-agent"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "README_EN.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./bridges": {
      "types": "./dist/bridges/index.d.ts",
      "default": "./dist/bridges/index.js"
    },
    "./helper": {
      "types": "./dist/helper/index.d.ts",
      "default": "./dist/helper/index.js"
    },
    "./process": {
      "types": "./dist/process/index.d.ts",
      "default": "./dist/process/index.js"
    },
    "./jni": {
      "types": "./dist/jni/index.d.ts",
      "default": "./dist/jni/index.js"
    },
    "./ssl": {
      "types": "./dist/ssl/index.d.ts",
      "default": "./dist/ssl/index.js"
    },
    "./elf": {
      "types": "./dist/elf/index.d.ts",
      "default": "./dist/elf/index.js"
    },
    "./elf/enhanced": {
      "types": "./dist/elf/enhanced/index.d.ts",
      "default": "./dist/elf/enhanced/index.js"
    },
    "./dex": {
      "types": "./dist/dex/index.d.ts",
      "default": "./dist/dex/index.js"
    },
    "./native/libssl": {
      "types": "./dist/native/libssl/index.d.ts",
      "default": "./dist/native/libssl/index.js"
    },
    "./native/libart": {
      "types": "./dist/native/libart/index.d.ts",
      "default": "./dist/native/libart/index.js"
    },
    "./native/libc": {
      "types": "./dist/native/libc/index.d.ts",
      "default": "./dist/native/libc/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "default": "./dist/rpc/index.js"
    }
  },
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.type-tests.json --noEmit"
  },
  "dependencies": {
    "frida-java-bridge": "^7.0.8"
  },
  "devDependencies": {
    "@types/frida-gum": "^18.7.2",
    "typescript": "^5.8.3"
  }
}
