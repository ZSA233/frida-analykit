{
  "name": "my-frida-agent",
  "version": "0.1.0",
  "description": "Custom agent workspace generated by frida-analykit",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "frida-compile index.ts -o _agent.js -c",
    "watch": "frida-compile index.ts -o _agent.js -w"
  },
  "dependencies": {
    "${agent_package_name}": "${agent_package_spec}",
    "frida-java-bridge": "^7.0.8"
  },
  "devDependencies": {
    "@types/frida-gum": "^18.7.2",
    "@types/node": "^18.19.3",
    "frida-compile": "^19.0.4",
    "typescript": "^5.8.3"
  }
}
